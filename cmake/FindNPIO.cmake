#[=======================================================================]
# FindNPIO
# -----------
# Find the NPIO library
#
#  find_package(NPIO [<version>] REQUIRED)
#
#    - NPIO_FOUND        - True if the library was found.
#    - NPIO_VERSION      - The version of the library.
#    - NPIO_INCLUDE_DIRS - The include directories for the library.
#    - NPIO_LIBRARIES    - The libraries to link against.
#==========================================================================]